# ==========================
# SkillGraph launcher config
# Copy this file to ".env" and edit values if needed.
# ==========================

# Optional: explicit WSL project path (if blank, launcher auto-detects via wslpath)
WSL_PROJECT_PATH=

# FastAPI target (python -m uvicorn <API_APP>)
API_APP=main:app
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_RELOAD=1

# Frontend static server
FRONTEND_PORT=5500
INDEX_FILE=index.html

# Python command and optional WSL venv activate path
PYTHON_BIN=python
VENV_ACTIVATE=venv/bin/activate

# Optional toggles
ENABLE_NEO4J_START=1
OPEN_BROWSER=1
